		{ id: 'q12', pillar: 'team', text: 'If you work with contractors or staff, how do tasks get assigned?', options: [
			{ score: 0, text: 'I tell them directly every time' },
			{ score: 33, text: 'We use a shared doc or chat, but I direct everything' },
			{ score: 67, text: 'There\'s a system but I still check in frequently' },
