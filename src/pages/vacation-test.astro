		{ id: 'q13', pillar: 'team', text: 'How does work get tracked when you\'re not checking in?', options: [
			{ score: 0, text: 'It doesn\'t — things fall through' },
			{ score: 33, text: 'People message me updates' },
			{ score: 67, text: 'We have a tracker but I need to push it' },
			{ score: 100, text: 'The system tracks progress and I get a summary' },
		]},
		{ id: 'q14', pillar: null, text: 'Be honest: when was the last time you took a real vacation — no checking email, no "just one quick call"?', options: [
			{ score: 0, text: 'I can\'t remember' },
			{ score: 33, text: 'Within the last year, but I checked in' },
			{ score: 67, text: 'Within the last year, fully disconnected' },
			{ score: 100, text: 'I take real vacations regularly because my business runs without me' },
		]},
		{ id: 'q15', pillar: null, text: 'If you doubled your clients next month, what would happen?', options: [
			{ score: 0, text: 'Chaos — I\'m at capacity already' },
			{ score: 33, text: 'I\'d manage but things would slip' },
