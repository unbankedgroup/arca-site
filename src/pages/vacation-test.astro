	// ── State ──
	let currentQ = 0;
	const answers = {};
	let businessType = null;
	let results = null;

	// ── Render question ──
	function renderQuestion(idx) {
		const q = QUESTIONS[idx];
		const container = document.getElementById('question-container');
		let html = '';

		if (q.type === 'vertical') {
			html = `<div class="vt-question active" data-q="${idx}">
				<div class="vt-pillar-tag">About You</div>
				<div class="vt-question-text">${q.text}</div>
				<div class="vt-verticals">
					${VERTICALS.map(v => `
						<button class="vt-vertical-card${answers[q.id] === v.id ? ' selected' : ''}" data-vertical="${v.id}" onclick="selectVertical(this)">
							<span class="vt-vertical-icon">${v.id === 'coach' ? '🎯' : v.id === 'consultant' ? '💼' : v.id === 'agency' ? '🚀' : '⚡'}</span>
							<div>
								<div class="vt-vertical-label">${v.label}</div>
								<div class="vt-vertical-desc">${v.desc}</div>
							</div>
						</button>
					`).join('')}
				</div>
				<div class="vt-nav">
					<button class="vt-btn-back" onclick="prevQuestion()" ${idx === 0 ? 'disabled' : ''}>Back</button>
					<button class="vt-btn-next" id="next-btn" ${answers[q.id] ? '' : 'disabled'} onclick="nextQuestion()">Continue</button>
				</div>
			</div>`;
		} else {
			const pillarObj = q.pillar ? PILLARS.find(p => p.id === q.pillar) : null;
			html = `<div class="vt-question active" data-q="${idx}">
				${pillarObj ? `<div class="vt-pillar-tag">${pillarObj.label}</div>` : ''}
				<div class="vt-question-text">${q.text}</div>
				<div class="vt-options">
					${q.options.map((opt, j) => `
						<button class="vt-option${answers[q.id] === opt.score ? ' selected' : ''}" data-score="${opt.score}" data-qid="${q.id}" onclick="selectOption(this)">
							<span class="vt-option-marker">${String.fromCharCode(65 + j)}</span>
							<span class="vt-option-text">${opt.text}</span>
						</button>
					`).join('')}
				</div>
				<div class="vt-nav">
					<button class="vt-btn-back" onclick="prevQuestion()">Back</button>
					<button class="vt-btn-next" id="next-btn" ${answers[q.id] !== undefined ? '' : 'disabled'} onclick="nextQuestion()">${idx === QUESTIONS.length - 1 ? 'See My Score' : 'Continue'}</button>
				</div>
			</div>`;
		}

		container.innerHTML = html;
		updateProgress(idx);
	}

	function updateProgress(idx) {
		const pct = Math.round(((idx + 1) / QUESTIONS.length) * 100);
		document.getElementById('progress-fill').style.width = `${pct}%`;
		document.getElementById('progress-label').textContent = `Question ${idx + 1} of ${QUESTIONS.length}`;
		document.getElementById('progress-pct').textContent = `${pct}%`;
	}

	// ── Selection handlers ──
	function selectVertical(btn) {
		document.querySelectorAll('.vt-vertical-card').forEach(c => c.classList.remove('selected'));
		btn.classList.add('selected');
		const q = QUESTIONS[currentQ];
		answers[q.id] = btn.dataset.vertical;
		businessType = btn.dataset.vertical;
		document.getElementById('next-btn').disabled = false;
	}

	function selectOption(btn) {
		const container = btn.closest('.vt-options');
		container.querySelectorAll('.vt-option').forEach(o => o.classList.remove('selected'));
		btn.classList.add('selected');
		const q = QUESTIONS[currentQ];
		answers[q.id] = parseInt(btn.dataset.score);
		document.getElementById('next-btn').disabled = false;
	}

	// ── Navigation ──
	function nextQuestion() {
		if (currentQ < QUESTIONS.length - 1) {
			currentQ++;
			renderQuestion(currentQ);
		} else {
			showResults();
		}
	}

	function prevQuestion() {
		if (currentQ > 0) {
			currentQ--;
			renderQuestion(currentQ);
		}
	}

	// ── Start quiz ──
	function startQuiz() {
		document.getElementById('vt-hero').style.display = 'none';
		document.getElementById('quiz').classList.add('active');
		renderQuestion(0);
	}

	// ── Scoring engine ──
	function computeResults() {
		const type = businessType || 'other';
		const weights = WEIGHTS[type] || WEIGHTS.other;

		// Raw pillar scores
		const pillars = {};
		for (const [pillar, qIds] of Object.entries(PILLAR_QUESTIONS)) {
			const vals = qIds.map(q => answers[q] ?? 0);
			pillars[pillar] = vals.reduce((a, b) => a + b, 0) / vals.length;
		}

		// Weighted composite
		let composite = 0;
		for (const [pillar, weight] of Object.entries(weights)) {
			composite += (pillars[pillar] || 0) * weight;
		}

		// Bonus modifiers from Q14, Q15
		const bonusMod = (score) => score === 0 ? -5 : score === 33 ? -2 : score === 67 ? 2 : 5;
		const q14mod = bonusMod(answers.q14 ?? 0);
		const q15mod = bonusMod(answers.q15 ?? 0);

		const final = Math.max(0, Math.min(100, Math.round(composite + q14mod + q15mod)));

		// Tier
		const tier = TIERS.find(t => final <= t.max);

		// Gaps (pillars below 60)
		const gaps = Object.entries(pillars)
			.filter(([, score]) => score < 60)
			.sort(([, a], [, b]) => a - b);

		return { score: final, tier, pillars, gaps, businessType: type };
	}

	// ── Show results ──
		// ── Show results ──
		function showResults() {
			results = computeResults();

			// Hide quiz, show results
			document.getElementById('quiz').style.display = 'none';
			document.getElementById('results').classList.add('visible');

			// Animate pre-gate score
			animateNumber(document.getElementById('total-score'), 0, results.score, 800);
			document.getElementById('tier-label').textContent = results.tier.label;
			document.getElementById('score-headline').textContent = results.tier.headline;
			document.getElementById('score-summary').textContent = results.tier.summary;

			// Populate VacationTestResults component
			const pillarScores = {};
			for (const [pillar, score] of Object.entries(results.pillars)) {
				pillarScores[pillar] = Math.round(score);
			}
			if (window.renderResults) {
				window.renderResults(pillarScores, results.businessType);
				window.setFinalScore(results.score);
			}

			// Scroll to results
			document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
		}

	// ── Unlock full results ──
		// ── Unlock full results ──
		function unlockResults() {
			document.getElementById('email-gate').style.display = 'none';
			document.getElementById('full-results').classList.add('visible');
			document.getElementById('cta-section').style.display = 'block';

			// Draw radar chart on component canvas
			drawRadar();

			// Reveal action plan + share buttons (behind email gate)
			if (window.revealFullResults) {
				window.revealFullResults();
			}
		}

	// ── Radar chart (Canvas, no library) ──
	function drawRadar() {
		const canvas = document.getElementById('results-radar-chart');
		const ctx = canvas.getContext('2d');
		const dpr = window.devicePixelRatio || 1;
		const size = 420;
		canvas.width = size * dpr;
		canvas.height = size * dpr;
		canvas.style.width = size + 'px';
		canvas.style.height = size + 'px';
		ctx.scale(dpr, dpr);

		const cx = size / 2;
		const cy = size / 2;
		const maxR = size / 2 - 60;
		const n = PILLARS.length;
		const angleStep = (2 * Math.PI) / n;
		const startAngle = -Math.PI / 2;

		// Reference circles
		[25, 50, 75, 100].forEach(pct => {
			const r = maxR * (pct / 100);
			ctx.beginPath();
			ctx.arc(cx, cy, r, 0, Math.PI * 2);
			ctx.strokeStyle = pct === 50 ? 'rgba(184, 116, 61, 0.25)' : 'rgba(217, 207, 187, 0.4)';
			ctx.lineWidth = pct === 50 ? 1.5 : 1;
			ctx.setLineDash(pct === 50 ? [] : [3, 3]);
			ctx.stroke();
			ctx.setLineDash([]);
		});

		// Axis lines
		for (let i = 0; i < n; i++) {
			const angle = startAngle + i * angleStep;
			ctx.beginPath();
			ctx.moveTo(cx, cy);
			ctx.lineTo(cx + maxR * Math.cos(angle), cy + maxR * Math.sin(angle));
			ctx.strokeStyle = 'rgba(217, 207, 187, 0.5)';
			ctx.lineWidth = 1;
			ctx.stroke();
		}

		// Data polygon
		const points = PILLARS.map((p, i) => {
			const val = (results.pillars[p.id] || 0) / 100;
			const angle = startAngle + i * angleStep;
			return {
				x: cx + maxR * val * Math.cos(angle),
				y: cy + maxR * val * Math.sin(angle),
			};
		});

		// Fill
		ctx.beginPath();
		points.forEach((pt, i) => i === 0 ? ctx.moveTo(pt.x, pt.y) : ctx.lineTo(pt.x, pt.y));
		ctx.closePath();
		ctx.fillStyle = 'rgba(184, 116, 61, 0.15)';
		ctx.fill();

		// Stroke
		ctx.beginPath();
		points.forEach((pt, i) => i === 0 ? ctx.moveTo(pt.x, pt.y) : ctx.lineTo(pt.x, pt.y));
		ctx.closePath();
		ctx.strokeStyle = 'rgba(184, 116, 61, 0.9)';
		ctx.lineWidth = 2.5;
		ctx.stroke();

		// Points
		points.forEach(pt => {
			ctx.beginPath();
			ctx.arc(pt.x, pt.y, 5, 0, Math.PI * 2);
			ctx.fillStyle = '#B8743D';
			ctx.fill();
			ctx.strokeStyle = '#fff';
			ctx.lineWidth = 2;
			ctx.stroke();
		});

		// Labels
		ctx.fillStyle = '#3A3632';
		ctx.font = "600 12px 'Plus Jakarta Sans', sans-serif";
		ctx.textAlign = 'center';
		ctx.textBaseline = 'middle';
		PILLARS.forEach((p, i) => {
			const angle = startAngle + i * angleStep;
			const labelR = maxR + 32;
			const x = cx + labelR * Math.cos(angle);
			const y = cy + labelR * Math.sin(angle);
			ctx.fillText(p.label, x, y);
		});

		// Score at center
		ctx.fillStyle = '#151413';
		ctx.font = "800 36px 'Plus Jakarta Sans', sans-serif";
		ctx.textAlign = 'center';
		ctx.textBaseline = 'middle';
		ctx.fillText(results.score, cx, cy - 6);
		ctx.fillStyle = '#8A8278';
		ctx.font = "500 11px 'JetBrains Mono', monospace";
		ctx.fillText('/ 100', cx, cy + 18);
	}

	// ── Email submission ──
	function submitEmail(e) {
		e.preventDefault();
		const email = document.getElementById('gate-email').value;
		if (!email) return;
		const firstName = document.getElementById('gate-first').value || '';

		// Store locally
		localStorage.setItem('vt-results', JSON.stringify({ ...results, email, firstName }));

		// POST to endpoint (fire and forget)
		fetch('https://api.runarca.xyz/lead', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				email,
				firstName,
				score: results.score,
				tier: results.tier.label,
				businessType: results.businessType,
				topGap: results.gaps[0]?.[0] || '',
				source: 'vacation-test',
			}),
		}).catch(() => {});

		unlockResults();
	}

	// ── Animate number ──
	function animateNumber(el, from, to, duration) {
		const start = performance.now();
		function tick(now) {
			const p = Math.min((now - start) / duration, 1);
			const eased = 1 - Math.pow(1 - p, 3);
			el.textContent = Math.round(from + (to - from) * eased);
			if (p < 1) requestAnimationFrame(tick);
		}
		requestAnimationFrame(tick);
	}

	// ── Check for existing results in localStorage ──
	(function() {
		const saved = localStorage.getItem('vt-results');
		if (saved) {
			try {
				const parsed = JSON.parse(saved);
				if (parsed.score !== undefined) {
					results = parsed;
					// Restore answers for nav
					Object.assign(answers, parsed.answers || {});
					businessType = parsed.businessType;
				}
			} catch(e) {}
		}
	})();
	</script>
</body>
</html>