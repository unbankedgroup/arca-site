---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import VacationTestResults from '../components/VacationTest/VacationTestResults.astro';

const pageTitle = 'Vacation Readiness Test — Can Your Business Survive Without You? | Arca';
const pageDescription = 'Take the 5-minute Vacation Readiness Diagnostic. Score your business across 6 operational pillars and find out if you can truly step away.';
const canonicalUrl = 'https://runarca.xyz/vacation-test';
// Dynamic OG image — the template at /og-vacation-test-template.html reads score/tier params
const ogImageUrl = 'https://runarca.xyz/og-vacation-test.png';

const diagnosticJsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebApplication',
			'name': 'Vacation Readiness Diagnostic',
			'description': pageDescription,
			'url': canonicalUrl,
			'applicationCategory': 'BusinessApplication',
			'operatingSystem': 'Any',
			'offers': {
				'@type': 'Offer',
				'price': '0',
				'priceCurrency': 'USD',
			},
			'isPartOf': {
				'@type': 'WebSite',
				'name': 'Arca',
				'url': 'https://runarca.xyz',
			},
		},
		{
			'@type': 'Organization',
			'name': 'Arca',
			'url': 'https://runarca.xyz',
			'description': 'Operations platform for coaches, consultants, and service businesses.',
			'founder': {
				'@type': 'Person',
				'name': 'Mal Mposha',
			},
		},
	],
};
---

<html lang="en">
<head>
	<BaseHead
		title={pageTitle}
		description={pageDescription}
		canonicalUrl={canonicalUrl}
		ogImageUrl={ogImageUrl}
		articleJsonLd={diagnosticJsonLd}
	/>
	<style>
		/* ── Vacation Test: Vellum & Ink ── */
		.vt-page {
			background: var(--vellum);
			min-height: 100vh;
		}

		/* Hero */
		.vt-hero {
			max-width: 720px;
			margin: 0 auto;
			padding: 5rem 1.5rem 2rem;
			text-align: center;
		}
		.vt-hero .eyebrow {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.18em;
			color: var(--ochre);
			margin-bottom: 1.25rem;
			display: block;
		}
		.vt-hero h1 {
			font-size: clamp(2.25rem, 6vw, 3.5rem);
			font-weight: 800;
			color: var(--ink);
			line-height: 1.08;
			letter-spacing: -0.03em;
			margin: 0 0 1.25rem;
		}
		.vt-hero h1 em {
			font-family: 'Instrument Serif', 'Times New Roman', Georgia, serif;
			font-style: italic;
			font-weight: 400;
			color: var(--ochre);
		}
		.vt-hero .tagline {
			font-size: clamp(1rem, 2vw, 1.25rem);
			color: var(--ink-muted);
			max-width: 560px;
			margin: 0 auto 2rem;
			line-height: 1.6;
		}
		.vt-hero .trust {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			letter-spacing: 0.04em;
			color: var(--ink-haze);
			margin-top: 1.5rem;
		}
		.vt-start-btn {
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			padding: 1rem 2.5rem;
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-weight: 700;
			font-size: 1.0625rem;
			color: #fff;
			background: var(--ochre);
			border: none;
			border-radius: 100px;
			cursor: pointer;
			box-shadow: 0 4px 20px rgba(184, 116, 61, 0.35);
			transition: all 0.25s var(--ease);
		}
		.vt-start-btn:hover {
			background: var(--ochre-deep);
			box-shadow: 0 6px 28px rgba(184, 116, 61, 0.45);
			transform: translateY(-2px);
		}

		/* Quiz container */
		.vt-quiz {
			max-width: 640px;
			margin: 0 auto;
			padding: 0 1.5rem 4rem;
			display: none;
		}
		.vt-quiz.active { display: block; }

		/* Progress */
		.vt-progress-wrap { margin-bottom: 2rem; }
		.vt-progress-label {
			display: flex;
			justify-content: space-between;
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			font-weight: 500;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--ink-haze);
			margin-bottom: 0.5rem;
		}
		.vt-progress-bar {
			height: 4px;
			background: var(--line);
			border-radius: 100px;
			overflow: hidden;
		}
		.vt-progress-fill {
			height: 100%;
			background: var(--ochre);
			border-radius: 100px;
			transition: width 0.4s var(--ease);
		}

		/* Question card */
		.vt-question { display: none; }
		.vt-question.active {
			display: block;
			animation: vt-fade-in 0.3s ease;
		}
		@keyframes vt-fade-in {
			from { opacity: 0; transform: translateY(12px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.vt-pillar-tag {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			color: var(--ochre);
			margin-bottom: 0.75rem;
		}
		.vt-question-text {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-size: clamp(1.25rem, 3vw, 1.5rem);
			font-weight: 700;
			color: var(--ink);
			line-height: 1.3;
			margin-bottom: 1.5rem;
		}

		/* Vertical cards (Q1) */
		.vt-verticals {
			display: grid;
			grid-template-columns: 1fr;
			gap: 0.75rem;
			margin-bottom: 2rem;
		}
		.vt-vertical-card {
			display: flex;
			align-items: center;
			gap: 1rem;
			padding: 1.25rem 1.5rem;
			background: var(--vellum);
			border: 2px solid var(--line);
			border-radius: var(--radius);
			cursor: pointer;
			transition: all 0.2s var(--ease);
			text-align: left;
			width: 100%;
		}
		.vt-vertical-card:hover {
			border-color: var(--ochre);
			transform: translateY(-2px);
			box-shadow: var(--shadow);
		}
		.vt-vertical-card.selected {
			border-color: var(--ochre);
			background: var(--ochre-light);
			box-shadow: var(--shadow);
		}
		.vt-vertical-icon { font-size: 1.5rem; flex-shrink: 0; }
		.vt-vertical-label {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-weight: 700;
			font-size: 1rem;
			color: var(--ink);
		}
		.vt-vertical-desc {
			font-size: 0.8125rem;
			color: var(--ink-muted);
			margin-top: 0.15rem;
		}

		/* Answer options */
		.vt-options {
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
			margin-bottom: 2rem;
		}
		.vt-option {
			display: flex;
			align-items: flex-start;
			gap: 0.875rem;
			padding: 1rem 1.25rem;
			background: var(--vellum);
			border: 2px solid var(--line);
			border-radius: var(--radius);
			cursor: pointer;
			transition: all 0.2s var(--ease);
			text-align: left;
			width: 100%;
		}
		.vt-option:hover {
			border-color: var(--ochre);
			transform: translateY(-1px);
		}
		.vt-option.selected {
			border-color: var(--ochre);
			background: var(--ochre-light);
		}
		.vt-option-marker {
			flex-shrink: 0;
			width: 24px;
			height: 24px;
			border-radius: 50%;
			border: 2px solid var(--line);
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			font-weight: 700;
			color: var(--ink-haze);
			margin-top: 2px;
			transition: all 0.2s var(--ease);
		}
		.vt-option.selected .vt-option-marker {
			border-color: var(--ochre);
			background: var(--ochre);
			color: #fff;
		}
		.vt-option-text {
			font-family: 'Inter', sans-serif;
			font-size: 0.9375rem;
			line-height: 1.5;
			color: var(--ink-soft);
		}
		.vt-option.selected .vt-option-text { color: var(--ink); }

		/* Nav buttons */
		.vt-nav {
			display: flex;
			justify-content: space-between;
			gap: 1rem;
		}
		.vt-btn-back {
			padding: 0.75rem 1.5rem;
			font-family: 'Inter', sans-serif;
			font-weight: 600;
			font-size: 0.9375rem;
			color: var(--ink-muted);
			background: transparent;
			border: 1.5px solid var(--line);
			border-radius: 100px;
			cursor: pointer;
			transition: all 0.2s var(--ease);
		}
		.vt-btn-back:hover { border-color: var(--ink-soft); color: var(--ink); }
		.vt-btn-back:disabled { opacity: 0.3; cursor: not-allowed; }
		.vt-btn-next {
			padding: 0.75rem 2rem;
			font-family: 'Inter', sans-serif;
			font-weight: 700;
			font-size: 0.9375rem;
			color: #fff;
			background: var(--ochre);
			border: none;
			border-radius: 100px;
			cursor: pointer;
			box-shadow: 0 2px 12px rgba(184, 116, 61, 0.3);
			transition: all 0.25s var(--ease);
		}
		.vt-btn-next:hover {
			background: var(--ochre-deep);
			box-shadow: 0 4px 20px rgba(184, 116, 61, 0.4);
			transform: translateY(-1px);
		}
		.vt-btn-next:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

		/* ── Results ── */
		.vt-results {
			display: none;
			max-width: 800px;
			margin: 0 auto;
			padding: 0 1.5rem 4rem;
		}
		.vt-results.visible {
			display: block;
			animation: vt-fade-in 0.5s ease;
		}

		/* Pre-gate: composite score only */
		.vt-pre-gate {
			text-align: center;
			padding: 3rem 0;
		}
		.vt-tier-label {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.18em;
			color: var(--ochre);
			margin-bottom: 0.75rem;
		}
		.vt-score-number {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-size: clamp(4.5rem, 14vw, 8rem);
			font-weight: 800;
			line-height: 1;
			letter-spacing: -0.04em;
			color: var(--ink);
		}
		.vt-score-of {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.875rem;
			color: var(--ink-haze);
			letter-spacing: 0.08em;
			margin-bottom: 1rem;
		}
		.vt-score-headline {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-size: clamp(1.25rem, 3vw, 1.625rem);
			font-weight: 800;
			color: var(--ink);
			line-height: 1.25;
			margin-bottom: 0.75rem;
		}
		.vt-score-summary {
			font-size: 1.0625rem;
			color: var(--ink-muted);
			max-width: 520px;
			margin: 0 auto;
			line-height: 1.6;
		}

		/* Email gate */
		.vt-gate {
			max-width: 560px;
			margin: 3rem auto;
			background: var(--vellum);
			border: 2px solid var(--ochre);
			border-radius: var(--radius-lg);
			padding: 2.5rem 2rem;
			text-align: center;
		}
		.vt-gate h3 {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-size: 1.375rem;
			font-weight: 800;
			color: var(--ink);
			margin-bottom: 0.5rem;
		}
		.vt-gate p {
			font-size: 0.9375rem;
			color: var(--ink-muted);
			margin-bottom: 1.5rem;
			line-height: 1.55;
		}
		.vt-gate-form {
			display: flex;
			gap: 0.5rem;
			margin-bottom: 0.5rem;
		}
		.vt-gate-input {
			flex: 1;
			padding: 0.875rem 1.25rem;
			border: 2px solid var(--line);
			border-radius: 100px;
			font-family: 'Inter', sans-serif;
			font-size: 0.9375rem;
			color: var(--ink);
			background: #fff;
			transition: border-color 0.2s var(--ease);
		}
		.vt-gate-input:focus { outline: none; border-color: var(--ochre); }
		.vt-gate-input::placeholder { color: var(--ink-haze); }
		.vt-gate-submit {
			padding: 0.875rem 1.75rem;
			background: var(--ochre);
			color: #fff;
			border: none;
			border-radius: 100px;
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-weight: 700;
			font-size: 0.9375rem;
			cursor: pointer;
			box-shadow: 0 2px 12px rgba(184, 116, 61, 0.3);
			transition: all 0.25s var(--ease);
			white-space: nowrap;
		}
		.vt-gate-submit:hover {
			background: var(--ochre-deep);
			box-shadow: 0 4px 20px rgba(184, 116, 61, 0.4);
			transform: translateY(-1px);
		}
		.vt-gate-disclaimer {
			font-size: 0.75rem;
			color: var(--ink-haze);
			margin-top: 0.75rem;
		}
		.vt-gate-form-row {
			display: flex;
			gap: 0.5rem;
			margin-bottom: 0.75rem;
		}

		/* Full results (post-gate) */
		.vt-full-results { display: none; }
		.vt-full-results.visible { display: block; }

		/* Radar chart */
		.vt-chart-wrap {
			background: #fff;
			border: 1px solid var(--line);
			border-radius: var(--radius-lg);
			padding: 2rem 1.5rem;
			margin-bottom: 2.5rem;
			position: relative;
		}
		.vt-chart-title {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.14em;
			color: var(--ochre);
			text-align: center;
			margin-bottom: 1rem;
		}
		.vt-chart-canvas {
			max-width: 460px;
			margin: 0 auto;
			display: block;
		}

		/* Pillar cards */
		.vt-pillars {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.75rem;
			margin-bottom: 2.5rem;
		}
		.vt-pillar-card {
			background: var(--vellum);
			border: 1px solid var(--line);
			border-radius: var(--radius);
			padding: 1rem 1.25rem;
			transition: all 0.2s var(--ease);
		}
		.vt-pillar-card.worst {
			border-color: var(--ochre);
			background: var(--ochre-light);
		}
		.vt-pillar-header {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			margin-bottom: 0.35rem;
		}
		.vt-pillar-name {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-weight: 700;
			font-size: 0.9375rem;
			color: var(--ink);
		}
		.vt-pillar-score {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.875rem;
			font-weight: 700;
			color: var(--ochre);
		}
		.vt-pillar-bar {
			height: 6px;
			background: var(--line);
			border-radius: 100px;
			overflow: hidden;
			margin-top: 0.5rem;
		}
		.vt-pillar-fill {
			height: 100%;
			border-radius: 100px;
			background: var(--ochre);
			transition: width 0.8s var(--ease);
		}

		/* Action plan */
		.vt-action-plan {
			background: var(--ink);
			color: var(--vellum);
			border-radius: var(--radius-lg);
			padding: 2.5rem 2rem;
			margin-bottom: 2.5rem;
		}
		.vt-action-title {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.18em;
			color: var(--ochre);
			margin-bottom: 0.75rem;
		}
		.vt-action-headline {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-size: clamp(1.25rem, 2.5vw, 1.625rem);
			font-weight: 800;
			line-height: 1.2;
			color: var(--vellum);
			margin-bottom: 1.5rem;
		}
		.vt-action-step {
			display: flex;
			gap: 1rem;
			margin-bottom: 1.25rem;
		}
		.vt-action-num {
			flex-shrink: 0;
			width: 28px;
			height: 28px;
			border-radius: 50%;
			background: var(--ochre);
			color: #fff;
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.75rem;
			font-weight: 700;
			margin-top: 2px;
		}
		.vt-action-step h4 {
			font-family: 'Plus Jakarta Sans', sans-serif;
			font-size: 1rem;
			font-weight: 700;
			color: var(--vellum);
			margin-bottom: 0.25rem;
		}
		.vt-action-step p {
			font-size: 0.9375rem;
			color: rgba(244, 239, 230, 0.7);
			line-height: 1.5;
			margin: 0;
		}
		.vt-action-timeline {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			color: var(--ochre);
			letter-spacing: 0.04em;
			margin-top: 1.5rem;
			padding-top: 1rem;
			border-top: 1px solid rgba(244, 239, 230, 0.12);
		}

		/* Share section */
		.vt-share {
			text-align: center;
			margin-top: 2.5rem;
			padding-top: 2rem;
			border-top: 1px solid var(--line);
		}
		.vt-share-label {
			font-family: 'JetBrains Mono', monospace;
			font-size: 0.6875rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.14em;
			color: var(--ink-haze);
			margin-bottom: 1rem;
		}
		.vt-share-links {
			display: flex;
			justify-content: center;
			gap: 0.75rem;
			flex-wrap: wrap;
		}
		.vt-share-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.5rem;
			padding: 0.75rem 1.25rem;
			border: 1.5px solid var(--line);
			border-radius: 100px;
			font-family: 'Inter', sans-serif;
			font-size: 0.8125rem;
			font-weight: 600;
			color: var(--ink-soft);
			background: var(--vellum);
			cursor: pointer;
			transition: all 0.2s var(--ease);
			text-decoration: none;
		}
		.vt-share-btn:hover {
			border-color: var(--ochre);
			color: var(--ochre);
			transform: translateY(-1px);
		}
		.vt-share-btn svg { width: 16px; height: 16px; }

		/* CTA */
		.vt-cta {
			max-width: 800px;
			margin: 0 auto;
			padding: 0 1.5rem 5rem;
			text-align: center;
		}
		.vt-cta-box {
			background: var(--ink);
			color: var(--vellum);
			border-radius: var(--radius-lg);
			padding: 3rem 2rem;
		}
		.vt-cta-box h2 {
			font-size: clamp(1.5rem, 3vw, 2rem);
			color: var(--vellum);
			margin-bottom: 1rem;
		}
		.vt-cta-box p {
			color: rgba(244, 239, 230, 0.75);
			max-width: 480px;
			margin: 0 auto 1.5rem;
			line-height: 1.6;
		}
		.vt-cta-box .btn-primary { font-size: 1rem; padding: 1rem 2.5rem; }

		/* Responsive */
		@media (max-width: 640px) {
			.vt-hero { padding: 3.5rem 1.25rem 2rem; }
			.vt-pillars { grid-template-columns: 1fr; }
			.vt-gate-form, .vt-gate-form-row { flex-direction: column; }
			.vt-gate-submit { width: 100%; }
			.vt-cta-box { padding: 2rem 1.25rem; }
		}
	</style>
</head>
<body class="vt-page">
	<nav class="site-nav">
		<div class="nav-inner">
			<a href="/" class="brand"><span class="brand-mark">Arca</span></a>
			<nav class="nav-links">
				<a href="/">Home</a>
				<a href="/blog/">Learn</a>
				<a href="/vacation-test" class="active">Vacation Test</a>
			</nav>
			<div class="nav-cta">
				<a href="/#waitlist" class="btn btn-primary btn-sm">Get started</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero -->
		<section class="vt-hero" id="vt-hero">
			<span class="eyebrow">Free 5-Minute Diagnostic</span>
			<h1>Can your business survive <em>two weeks</em> without you?</h1>
			<p class="tagline">Take the Vacation Readiness Diagnostic. Get your score across 6 operational pillars, see your biggest gap, and find out what it takes to pass the vacation test.</p>
			<button class="vt-start-btn" onclick="startQuiz()">Start the Test</button>
			<div class="trust">Based on research from the U.S. Travel Association, Freelancers Union, and Boston Consulting Group</div>
