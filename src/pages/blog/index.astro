---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const SITE_TITLE = 'Learn — Arca';
const SITE_DESCRIPTION = 'Practical guides on operations, automation, and running a service business without burning out. Built for coaches and consultants.';

const allPosts = await getCollection('blog');

// Cluster metadata
const clusterLabels: Record<string, string> = {
	C1: 'Managed Operations',
	C2: 'Automation for Service Businesses',
	C3: 'Operations & Productivity',
	C4: 'Tool Alternatives & Comparisons',
	C5: 'VAs vs Operations Platforms',
	C6: 'Client Onboarding & Revenue Ops',
};

const clusterDecks: Record<string, string> = {
	C1: 'What managed operations actually means — and why done-for-you beats DIY for solo operators.',
	C2: 'Automate the boring parts of a service business without turning into a Zapier monster.',
	C3: 'Systems, rituals, and checklists for doing more of the work you actually want to do.',
	C4: 'Honest comparisons of the tools solo operators use every day — what works, what doesn\'t.',
	C5: 'Hiring a VA vs. buying an operations platform. Costs, trade-offs, and when to do which.',
	C6: 'Turning new leads into paying clients without ghosting them in the inbox.',
};

// Group posts by cluster
const clusters: Record<string, typeof allPosts> = {};
for (const post of allPosts) {
	const pCluster = (post.data as any).cluster;
	const match = pCluster ? String(pCluster).match(/^(C\d+)/) : null;
	const key = match ? match[1] : 'OTHER';
	if (!clusters[key]) clusters[key] = [];
	clusters[key].push(post);
}

// Sort clusters: pillars first
for (const key in clusters) {
	clusters[key].sort((a, b) => {
		const aPillar = String((a.data as any).id || a.id || '').toLowerCase().includes('pillar');
		const bPillar = String((b.data as any).id || b.id || '').toLowerCase().includes('pillar');
		if (aPillar && !bPillar) return -1;
		if (!aPillar && bPillar) return 1;
		return a.id.localeCompare(b.id);
	});
}

// Hero feature: C1 pillar (the big managed ops guide)
const heroFeature = allPosts.find((p) => p.id === 'c1-pillar-managed-operations-guide');

// Start here: 3 evergreen anchors
const startHereIds = [
	'business-runs-without-you',
	'operations-audit-checklist',
	'7-day-build-explained',
];
const startHere = startHereIds
	.map((id) => allPosts.find((p) => p.id === id))
	.filter(Boolean) as typeof allPosts;

const orderedClusters = ['C1', 'C2', 'C3', 'C4', 'C5', 'C6'].filter((k) => clusters[k]);

const readingMinutes = (wc: any): number => {
	if (!wc) return 5;
	const n = parseInt(String(wc).replace(/[^0-9]/g, ''), 10);
	return n > 0 ? Math.max(1, Math.round(n / 220)) : 5;
};
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-hero">
				<div class="container">
					<div class="eyebrow-big">Arca · Learn</div>
					<h1>The operations playbook for solo coaches and consultants.</h1>
					<p class="lede">
						Practical guides on automation, client systems, and running a service business
						without burning out. Written for the people doing the actual work.
					</p>
				</div>
			</section>

			<div class="blog-search">
				<div id="search"></div>
			</div>
			<link rel="stylesheet" href="/blog/pagefind/pagefind-ui.css" />
			<script src="/blog/pagefind/pagefind-ui.js" is:inline></script>

			<nav class="category-nav" aria-label="Clusters">
				<div class="category-nav-inner">
					<a href="#all" class="active" data-cluster="all">All</a>
					{orderedClusters.map((k) => (
						<a href={`#${k.toLowerCase()}`} data-cluster={k}>{clusterLabels[k]}</a>
					))}
				</div>
			</nav>

			<div class="container" id="all">
				{heroFeature && (
					<a href={`/blog/${heroFeature.id}/`} class="hero-feature">
						<div>
							<span class="eyebrow">Featured pillar · {clusterLabels.C1}</span>
							<h2>{heroFeature.data.title}</h2>
							<p>{heroFeature.data.meta_description || heroFeature.data.description}</p>
							<span class="hero-feature-cta">Read the guide →</span>
						</div>
						<div class="hero-feature-stats">
							<div class="hf-stat"><span class="num">{readingMinutes((heroFeature.data as any).word_count)}</span><span class="lbl">min read</span></div>
							<div class="hf-stat"><span class="num">{clusters.C1?.length || 0}</span><span class="lbl">supporting posts</span></div>
							<div class="hf-stat"><span class="num">6</span><span class="lbl">clusters</span></div>
						</div>
					</a>
				)}

				{startHere.length > 0 && (
					<div class="start-here">
						<div class="start-here-label">New to Arca ops? Start with these</div>
						<div class="start-here-grid">
							{startHere.map((post, i) => (
								<a href={`/blog/${post.id}/`} class="start-here-card">
									<span class="num">0{i + 1}</span>
									<h4>{post.data.title}</h4>
									<p>{((post.data.meta_description || post.data.description || '') as string).slice(0, 110)}…</p>
								</a>
							))}
						</div>
					</div>
				)}

				{orderedClusters.map((key, idx) => {
					const posts = clusters[key].slice(0, 7);
					return (
						<section class="cluster-section" id={key.toLowerCase()} data-cluster-section={key}>
							<header class="cluster-header">
								<div class="cluster-num">0{idx + 1}</div>
								<div class="cluster-info">
									<h2>{clusterLabels[key]}</h2>
									<p class="cluster-deck">{clusterDecks[key]}</p>
								</div>
								<a href={`#${key.toLowerCase()}`} class="cluster-view-all">View all ({clusters[key].length})</a>
							</header>
							<div class="cluster-grid">
								{posts.map((post, i) => {
									const data = post.data as any;
									const desc = (data.meta_description || data.description || '') as string;
									const minutes = readingMinutes(data.word_count);
									const isBig = i === 0;
									return (
										<a href={`/blog/${post.id}/`} class={`post-card ${isBig ? 'big' : ''}`} data-title={data.title.toLowerCase()} data-desc={desc.toLowerCase()}>
											<div class="post-eyebrow">{minutes} min · {clusterLabels[key]}</div>
											<h3>{data.title}</h3>
											{desc && <p>{desc.slice(0, isBig ? 180 : 120)}{desc.length > (isBig ? 180 : 120) ? '…' : ''}</p>}
										</a>
									);
								})}
							</div>
						</section>
					);
				})}

				<section class="inline-newsletter" style="margin: 5rem 0;">
					<h4>Get the next playbook</h4>
					<p>One operations deep-dive a week. No spam, just the stuff we'd tell a friend over coffee.</p>
					<form action="/#waitlist" method="get">
						<input type="email" name="email" placeholder="you@example.com" required />
						<button type="submit">Subscribe</button>
					</form>
				</section>
			</div>
		</main>
		<Footer />

		<script>
			// ===== Pagefind search UI =====
			window.addEventListener('DOMContentLoaded', () => {
				if (typeof (window as any).PagefindUI !== 'undefined') {
					new (window as any).PagefindUI({
						element: '#search',
						showSubResults: true,
						showImages: false,
						resetStyles: false,
						placeholder: 'Search articles…',
					});
				}
			});

			// ===== Sticky category nav active state =====
			const navLinks = document.querySelectorAll('.category-nav a');
			const clusterSections = document.querySelectorAll('[data-cluster-section]');
			if ('IntersectionObserver' in window && clusterSections.length > 0) {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								const key = (entry.target as HTMLElement).dataset.clusterSection;
								navLinks.forEach((a) => {
									a.classList.toggle('active', (a as HTMLElement).dataset.cluster === key);
								});
							}
						});
					},
					{ rootMargin: '-140px 0px -70% 0px', threshold: 0 }
				);
				clusterSections.forEach((s) => observer.observe(s));
			}
		</script>
	</body>
</html>

<style>
	.hero-feature {
		text-decoration: none;
	}
	.hero-feature-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(253, 250, 245, 0.1);
	}
	@media (min-width: 880px) {
		.hero-feature-stats {
			grid-template-columns: 1fr;
			padding-top: 0;
			border-top: none;
			border-left: 1px solid rgba(253, 250, 245, 0.1);
			padding-left: 2.5rem;
			align-self: stretch;
			align-content: center;
		}
	}
	.hf-stat { display: flex; flex-direction: column; }
	.hf-stat .num {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		font-weight: 800;
		color: var(--amber);
		line-height: 1;
	}
	.hf-stat .lbl {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(253, 250, 245, 0.6);
		margin-top: 0.35rem;
	}
</style>
