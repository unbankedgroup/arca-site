---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const SITE_TITLE = 'Learn — Arca';
const SITE_DESCRIPTION = 'Practical guides on operations, automation, and running a service business without burning out. Built for coaches and consultants.';

const allPosts = await getCollection('blog');

// Group posts by cluster
const clusters: Record<string, typeof allPosts> = {};
const clusterLabels: Record<string, string> = {
	C1: 'Managed Operations',
	C2: 'Automation for Service Businesses',
	C3: 'Operations & Productivity',
	C4: 'Tool Alternatives & Comparisons',
	C5: 'VAs vs Operations Platforms',
	C6: 'Client Onboarding & Revenue Ops',
};

for (const post of allPosts) {
	const id = post.data.id || '';
	const match = id.match(/^(C\d+)/);
	const clusterKey = match ? match[1] : 'OTHER';
	if (!clusters[clusterKey]) clusters[clusterKey] = [];
	clusters[clusterKey].push(post);
}

// Sort clusters: pillars first within each cluster
for (const key in clusters) {
	clusters[key].sort((a, b) => {
		const aIsPillar = (a.data.id || '').includes('-P') || (a.data.id || '').endsWith('PILLAR');
		const bIsPillar = (b.data.id || '').includes('-P') || (b.data.id || '').endsWith('PILLAR');
		if (aIsPillar && !bIsPillar) return -1;
		if (!aIsPillar && bIsPillar) return 1;
		return (a.data.id || '').localeCompare(b.data.id || '');
	});
}

// Featured post = C1 pillar
const featured = allPosts.find((p) => p.data.id === 'C1-P' || p.id === 'c1-pillar-managed-operations-guide');

const orderedClusters = ['C1', 'C2', 'C3', 'C4', 'C5', 'C6'].filter((k) => clusters[k]);
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="learn-hero">
				<div class="container">
					<a href="/" class="eyebrow">Arca · Learn</a>
					<h1>The operations playbook for solo coaches and consultants.</h1>
					<p class="lede">
						Practical guides on automation, client systems, and running a service business
						without burning out. Written for the people doing the actual work.
					</p>
				</div>
			</section>

			{featured && (
				<section class="featured">
					<div class="container">
						<a href={`/blog/${featured.id}/`} class="featured-card">
							<div class="featured-text">
								<span class="featured-tag">Featured guide</span>
								<h2>{featured.data.title}</h2>
								<p>{featured.data.meta_description || featured.data.description}</p>
								<span class="read-link">Read the guide →</span>
							</div>
						</a>
					</div>
				</section>
			)}

			{orderedClusters.map((key) => (
				<section class="cluster-section">
					<div class="container">
						<header class="cluster-header">
							<span class="cluster-num">{key}</span>
							<h2>{clusterLabels[key] || 'Articles'}</h2>
						</header>
						<div class="post-grid">
							{clusters[key].slice(0, 9).map((post) => (
								<a href={`/blog/${post.id}/`} class="post-card">
									<h3>{post.data.title}</h3>
									{(post.data.meta_description || post.data.description) && (
										<p>{(post.data.meta_description || post.data.description || '').slice(0, 140)}{(post.data.meta_description || post.data.description || '').length > 140 ? '…' : ''}</p>
									)}
									<span class="read-link">Read →</span>
								</a>
							))}
						</div>
					</div>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>

<style>
	.learn-hero {
		padding: 5rem 0 3rem;
		text-align: center;
	}

	.eyebrow {
		display: inline-block;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--amber);
		margin-bottom: 1.5rem;
		text-decoration: none;
	}

	.learn-hero h1 {
		font-size: clamp(2.25rem, 5vw, 3.75rem);
		font-weight: 800;
		line-height: 1.1;
		max-width: 800px;
		margin: 0 auto 1.5rem;
		color: var(--charcoal);
		letter-spacing: -0.025em;
	}

	.lede {
		font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
		line-height: 1.6;
		color: var(--soft-charcoal);
		max-width: 640px;
		margin: 0 auto;
	}

	.featured {
		padding: 2rem 0 4rem;
	}

	.featured-card {
		display: block;
		background: var(--charcoal);
		color: var(--canvas);
		border-radius: var(--radius-xl);
		padding: 4rem 3rem;
		text-decoration: none;
		transition: all 0.3s var(--ease);
	}

	.featured-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	.featured-tag {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--amber);
		margin-bottom: 1.25rem;
	}

	.featured-card h2 {
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		color: var(--canvas);
		margin-bottom: 1rem;
		max-width: 720px;
	}

	.featured-card p {
		font-size: 1.0625rem;
		line-height: 1.6;
		color: rgba(253, 250, 245, 0.8);
		max-width: 640px;
		margin-bottom: 1.5rem;
	}

	.featured-card .read-link {
		color: var(--amber);
		font-weight: 600;
		font-size: 1rem;
	}

	.cluster-section {
		padding: 3rem 0;
	}

	.cluster-header {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 2rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--cloud);
	}

	.cluster-num {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 0.75rem;
		font-weight: 800;
		color: var(--amber);
		background: var(--amber-light);
		padding: 0.25rem 0.625rem;
		border-radius: 100px;
		letter-spacing: 0.05em;
	}

	.cluster-header h2 {
		font-size: clamp(1.5rem, 2.5vw, 2rem);
		color: var(--charcoal);
		margin: 0;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.post-card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border: 1px solid var(--cloud);
		border-radius: var(--radius);
		padding: 1.75rem 1.5rem;
		text-decoration: none;
		transition: all 0.25s var(--ease);
	}

	.post-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
		border-color: var(--amber);
	}

	.post-card h3 {
		font-size: 1.125rem;
		line-height: 1.3;
		color: var(--charcoal);
		margin: 0 0 0.75rem 0;
	}

	.post-card p {
		font-size: 0.9375rem;
		line-height: 1.55;
		color: var(--soft-charcoal);
		margin: 0 0 1rem 0;
		flex: 1;
	}

	.post-card .read-link {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--amber);
	}

	@media (max-width: 900px) {
		.post-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.learn-hero {
			padding: 3rem 0 2rem;
		}

		.featured-card {
			padding: 2.5rem 1.75rem;
		}

		.post-grid {
			grid-template-columns: 1fr;
		}

		.cluster-header {
			flex-wrap: wrap;
		}
	}
</style>
