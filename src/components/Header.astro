---
import Mark from './Mark.astro';
const path = Astro.url.pathname;
const isBlog = path.startsWith('/blog');
const isStrategy = path.startsWith('/strategy');
---

<header class="site-nav" id="site-nav">
	<div class="nav-row">
		<a href="/" class="brand" aria-label="Arca home">
			<Mark variant="symbol" size={24} />
			<span class="brand-mark">arca</span>
		</a>

		<nav class="nav-links" aria-label="Primary">
			<a href="/" class={path === '/' ? 'active' : ''}>Home</a>
			<a href="/blog/" class={isBlog ? 'active' : ''}>Learn</a>
			<a href="/strategy" class={isStrategy ? 'active' : ''}>Strategy</a>
			<a href="/#pricing">Pricing</a>
			<a href="/#faq">FAQ</a>
		</nav>

		<div class="nav-cta">
			<a href="/#waitlist" class="btn-nav btn-nav-primary">
				Start your build
				<span class="arrow" aria-hidden="true">→</span>
			</a>
		</div>

		<button
			class="nav-hamburger"
			aria-label="Menu"
			aria-expanded="false"
			aria-controls="nav-drawer"
			onclick="const d=document.getElementById('nav-drawer'); const o=d.classList.toggle('open'); this.setAttribute('aria-expanded', o);"
		>
			<span></span><span></span><span></span>
		</button>
	</div>

	<div class="nav-drawer" id="nav-drawer" role="menu">
		<a href="/" role="menuitem">Home</a>
		<a href="/blog/" role="menuitem">Learn</a>
		<a href="/strategy" role="menuitem">Strategy</a>
		<a href="/#pricing" role="menuitem">Pricing</a>
		<a href="/#faq" role="menuitem">FAQ</a>
		<a href="/#waitlist" class="drawer-cta" role="menuitem">Start your build →</a>
	</div>
</header>

<script>
	const nav = document.getElementById('site-nav');
	let lastScrolled = false;
	function onScroll() {
		const scrolled = window.scrollY > 8;
		if (scrolled !== lastScrolled && nav) {
			nav.classList.toggle('scrolled', scrolled);
			lastScrolled = scrolled;
		}
	}
	window.addEventListener('scroll', onScroll, { passive: true });
	onScroll();
</script>

<style>
	.site-nav {
		position: sticky;
		top: 0;
		z-index: 1000;
		padding: 0.75rem 0;
		background: rgba(244, 239, 230, 0.72);
		backdrop-filter: saturate(180%) blur(14px);
		-webkit-backdrop-filter: saturate(180%) blur(14px);
		border-bottom: 1px solid transparent;
		transition: border-color 0.3s ease, background 0.3s ease;
	}

	.site-nav.scrolled {
		background: rgba(244, 239, 230, 0.9);
		border-bottom-color: var(--line-soft);
	}

	.nav-row {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-family: 'Instrument Serif', 'Times New Roman', serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.5rem;
		line-height: 1;
		color: var(--ink);
		letter-spacing: -0.03em;
		text-decoration: none;
	}

	.brand:hover { color: var(--ink); }

	.brand svg { flex-shrink: 0; }

	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.75rem;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.nav-links a {
		color: var(--ink-muted);
		text-decoration: none;
		transition: color 0.2s var(--ease);
		position: relative;
	}

	.nav-links a:hover {
		color: var(--ink);
	}

	.nav-links a.active {
		color: var(--ink);
		font-weight: 600;
	}

	.nav-links a.active::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: -6px;
		height: 2px;
		background: var(--amber);
		border-radius: 2px;
	}

	.nav-cta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.btn-nav {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.875rem;
		line-height: 1;
		padding: 0.625rem 1.1rem;
		border-radius: 6px;
		transition: background 0.2s var(--ease), color 0.2s var(--ease), transform 0.2s var(--ease);
		white-space: nowrap;
		text-decoration: none;
	}

	.btn-nav-primary {
		background: var(--ink);
		color: var(--paper);
	}

	.btn-nav-primary:hover {
		background: #050503;
		color: var(--paper);
		transform: translateY(-1px);
	}

	.btn-nav-primary .arrow {
		transition: transform 0.2s var(--ease);
	}

	.btn-nav-primary:hover .arrow {
		transform: translateX(3px);
	}

	.nav-hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 36px;
		height: 36px;
		padding: 6px;
		background: none;
		border: none;
		cursor: pointer;
	}

	.nav-hamburger span {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--ink);
		border-radius: 2px;
		transition: all 0.25s var(--ease);
	}

	.nav-drawer {
		display: none;
		flex-direction: column;
		padding: 0.5rem 1.5rem 1.25rem;
		gap: 0;
		background: rgba(244, 239, 230, 0.98);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		border-bottom: 1px solid var(--line-soft);
	}

	.nav-drawer a {
		display: block;
		padding: 0.875rem 0;
		font-size: 1rem;
		color: var(--ink);
		font-weight: 500;
		text-decoration: none;
		border-bottom: 1px solid var(--line-soft);
	}

	.nav-drawer a:last-child {
		border-bottom: none;
	}

	.nav-drawer a.drawer-cta {
		margin-top: 0.75rem;
		padding: 0.875rem 1.25rem;
		background: var(--ink);
		color: var(--paper);
		border-radius: 6px;
		font-weight: 600;
		text-align: center;
		border-bottom: none;
	}

	.nav-drawer.open {
		display: flex;
	}

	@media (max-width: 840px) {
		.nav-links {
			display: none;
		}

		.nav-cta {
			display: none;
		}

		.nav-hamburger {
			display: flex;
		}
	}
</style>
