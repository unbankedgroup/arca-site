---
import Mark from './Mark.astro';
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-grid">
			<div class="footer-brand">
				<a href="/" class="brand" aria-label="Arca home">
					<Mark variant="symbol" size={28} fg="var(--paper)" accent="var(--amber)" />
					<span class="brand-mark">arca</span>
				</a>
				<p class="tagline">Run your business in one chat.</p>
				<p class="parent">An <strong>Unbanked</strong> company.</p>
			</div>

			<div class="footer-col">
				<h4>Product</h4>
				<ul>
					<li><a href="/#how-it-works">How it works</a></li>
					<li><a href="/#pricing">Pricing</a></li>
					<li><a href="/#faq">FAQ</a></li>
					<li><a href="/#waitlist">Start your build</a></li>
				</ul>
			</div>

			<div class="footer-col">
				<h4>Learn</h4>
				<ul>
					<li><a href="/blog/">All articles</a></li>
					<li><a href="/blog/managed-operations-guide">Managed operations guide</a></li>
					<li><a href="/blog/crm-not-the-problem">The CRM isn't the problem</a></li>
					<li><a href="/blog/operations-cost-mistake">The operations cost mistake</a></li>
				</ul>
			</div>

			<div class="footer-col">
				<h4>Company</h4>
				<ul>
					<li><a href="/about/">About</a></li>
					<li><a href="mailto:hello@runarca.xyz">Contact</a></li>
					<li><a href="/privacy/">Privacy</a></li>
					<li><a href="/terms/">Terms</a></li>
				</ul>
			</div>
		</div>

		<div class="footer-bottom">
			<p>&copy; {today.getFullYear()} Arca. All rights reserved.</p>
			<p>Built for the small service businesses who'd rather do the work.</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--ink);
		color: rgba(244, 239, 230, 0.65);
		padding: 5rem 0 2rem;
		margin-top: 6rem;
	}

	.footer-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr 1fr;
		gap: 3rem;
		margin-bottom: 3.5rem;
	}

	.footer-brand .brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-family: 'Instrument Serif', 'Times New Roman', serif;
		font-style: italic;
		font-weight: 400;
		font-size: 1.875rem;
		line-height: 1;
		color: var(--paper);
		letter-spacing: -0.03em;
		text-decoration: none;
		margin-bottom: 1rem;
	}

	.footer-brand .brand svg { flex-shrink: 0; }

	.footer-brand .tagline {
		font-family: 'Instrument Serif', 'Times New Roman', serif;
		font-style: italic;
		font-size: 1.25rem;
		font-weight: 400;
		color: rgba(244, 239, 230, 0.9);
		margin-bottom: 1.25rem;
		max-width: 260px;
		line-height: 1.35;
		letter-spacing: -0.01em;
	}

	.footer-brand .parent {
		font-size: 0.8125rem;
		color: rgba(244, 239, 230, 0.45);
	}

	.footer-brand .parent strong {
		color: var(--paper);
		font-weight: 600;
	}

	.footer-col h4 {
		font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
		font-size: 0.6875rem;
		font-weight: 600;
		color: rgba(244, 239, 230, 0.6);
		text-transform: uppercase;
		letter-spacing: 0.14em;
		margin-bottom: 1.25rem;
	}

	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-col li {
		margin-bottom: 0.75rem;
	}

	.footer-col a {
		color: rgba(244, 239, 230, 0.72);
		font-size: 0.9375rem;
		text-decoration: none;
		transition: color 0.2s var(--ease);
	}

	.footer-col a:hover {
		color: var(--amber);
	}

	.footer-bottom {
		border-top: 1px solid rgba(244, 239, 230, 0.08);
		padding-top: 2rem;
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		font-size: 0.8125rem;
		color: rgba(244, 239, 230, 0.45);
	}

	@media (max-width: 768px) {
		.site-footer {
			padding: 3.5rem 0 1.5rem;
			margin-top: 4rem;
		}

		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 2.25rem 1.5rem;
			margin-bottom: 2.5rem;
		}

		.footer-brand {
			grid-column: 1 / -1;
		}

		.footer-bottom {
			flex-direction: column;
			text-align: center;
		}
	}
</style>
