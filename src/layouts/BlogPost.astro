---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { resolveCluster } from '../lib/clusters';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	prev?: { id: string; title: string } | null;
	next?: { id: string; title: string } | null;
	readingTime?: number;
	readingWords?: number;
};

const {
	title,
	description,
	meta_description,
	pubDate,
	updatedDate,
	last_updated,
	heroImage,
	author,
	cluster,
	slug,
	prev = null,
	next = null,
	readingTime,
	readingWords,
	word_count,
} = Astro.props;

const pageDescription = meta_description || description || '';
const authorName = typeof author === 'string' ? author : author?.name || 'Mal Mposha';
const authorRole = typeof author === 'object' ? author?.role : 'Founder, Arca';
const authorBio = typeof author === 'object' ? (author as any)?.bio : undefined;
const authorAvatar = typeof author === 'object' ? (author as any)?.avatar : undefined;

// Reading time — prefer build-time computed, fall back to manual word_count
const parseWordCount = (wc: string | number | undefined): number => {
	if (!wc) return 0;
	const n = parseInt(String(wc).replace(/[^0-9]/g, ''), 10);
	return n > 0 ? n : 0;
};
const readingMinutes =
	readingTime && readingTime > 0
		? readingTime
		: (() => {
				const wc = parseWordCount(word_count);
				return wc > 0 ? Math.max(1, Math.round(wc / 220)) : 5;
		  })();

// Cluster parsing — frontmatter is just the code (C1, C5…); resolve to label
const { code: clusterCode, label: categoryLabel } = resolveCluster(cluster as string | undefined);

// Current slug — prefer the explicit prop, else parse from pathname
const currentSlug =
	slug || Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '').replace(/\.html$/, '');

// Related posts: pull up to 3 from same cluster, excluding self, excluding prev/next
const allPosts = await getCollection('blog');
const relatedCandidates = allPosts.filter((p) => {
	if (p.id === currentSlug) return false;
	if (prev && p.id === prev.id) return false;
	if (next && p.id === next.id) return false;
	const pCluster = (p.data as any).cluster;
	if (!pCluster || !cluster) return false;
	const pCode = String(pCluster).match(/^(C\d+)/)?.[1];
	return pCode && pCode === clusterCode;
});
const related = relatedCandidates.slice(0, 3);

// Canonical post URL (avoids the base-path doubling Astro produces)
const canonicalUrl = `https://runarca.xyz/blog/${currentSlug}`;

// OG image URL — generated at build time by scripts/generate-og.mjs
const ogImageUrl = `https://runarca.xyz/blog/og/${currentSlug}.png`;

// Article JSON-LD — use frontmatter dates, never build time.
// Parses the human-readable `last_updated` string ("April 2026") when Date
// fields are absent, and omits dateModified entirely if no real date is
// available (better than shipping a wrong build-time value).
const toDate = (v: unknown): Date | undefined => {
	if (!v) return undefined;
	if (v instanceof Date) return isNaN(v.getTime()) ? undefined : v;
	if (typeof v === 'string') {
		const parsed = new Date(v);
		return isNaN(parsed.getTime()) ? undefined : parsed;
	}
	return undefined;
};
const publishedDate = toDate(pubDate) || toDate((Astro.props as any).date_published);
const modifiedDate =
	toDate(updatedDate) || toDate(last_updated) || publishedDate;
const canonicalId = `https://runarca.xyz/blog/${currentSlug}`;

const articleJsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: pageDescription,
	image: [ogImageUrl],
	author: {
		'@type': 'Person',
		name: authorName,
		url: 'https://runarca.xyz/',
	},
	publisher: {
		'@type': 'Organization',
		name: 'Arca',
		url: 'https://runarca.xyz/',
		logo: {
			'@type': 'ImageObject',
			url: 'https://runarca.xyz/favicon.svg',
		},
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalId,
	},
	wordCount: readingWords || parseWordCount(word_count) || undefined,
	articleSection: categoryLabel,
};
if (publishedDate) articleJsonLd.datePublished = publishedDate.toISOString();
if (modifiedDate) articleJsonLd.dateModified = modifiedDate.toISOString();

// Breadcrumb JSON-LD
const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://runarca.xyz/' },
		{ '@type': 'ListItem', position: 2, name: 'Learn', item: 'https://runarca.xyz/blog' },
		...(clusterCode
			? [
					{
						'@type': 'ListItem',
						position: 3,
						name: categoryLabel,
						item: `https://runarca.xyz/blog#${clusterCode.toLowerCase()}`,
					},
			  ]
			: []),
		{
			'@type': 'ListItem',
			position: clusterCode ? 4 : 3,
			name: title,
			item: canonicalId,
		},
	],
};

// Combined JSON-LD graph
const combinedJsonLd = {
	'@context': 'https://schema.org',
	'@graph': [articleJsonLd, breadcrumbJsonLd],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={pageDescription}
			ogImageUrl={ogImageUrl}
			canonicalUrl={canonicalUrl}
			articleJsonLd={combinedJsonLd}
			ogType="article"
			articlePublishedTime={publishedDate ? publishedDate.toISOString() : undefined}
			articleModifiedTime={modifiedDate ? modifiedDate.toISOString() : undefined}
			articleAuthor={authorName}
			articleSection={categoryLabel}
		/>
	</head>

	<body>
		<a href="#article-prose" class="skip-to-content">Skip to content</a>
		<Header />

		<div class="reading-progress" id="reading-progress"></div>

		<main class="article">
			<article>
				<nav class="breadcrumb" aria-label="Breadcrumb">
					<div class="breadcrumb-inner">
						<a href="/">Home</a>
						<span class="sep" aria-hidden="true">/</span>
						<a href="/blog/">Learn</a>
						{clusterCode && (
							<>
								<span class="sep" aria-hidden="true">/</span>
								<a href={`/blog/#${clusterCode.toLowerCase()}`}>{categoryLabel}</a>
							</>
						)}
					</div>
				</nav>

				<header class="article-header">
					<div class="prose-container">
						<a href={`/blog/#${clusterCode.toLowerCase()}`} class="eyebrow">{categoryLabel}</a>
						<h1 class="article-title">{title}</h1>
						{pageDescription && <p class="article-deck">{pageDescription}</p>}

						<div class="article-meta">
							{authorName && (
								<div class="byline">
									{authorAvatar ? (
										<img src={authorAvatar} alt={authorName} class="avatar avatar-img" width="36" height="36" />
									) : (
										<div class="avatar" aria-hidden="true">{authorName.charAt(0)}</div>
									)}
									<div class="byline-text">
										<div class="byline-name">{authorName}</div>
										{authorRole && <div class="byline-role">{authorRole}</div>}
									</div>
								</div>
							)}
							<div class="meta-divider" aria-hidden="true">·</div>
							<div class="meta-item">{readingMinutes} min read</div>
							{(last_updated || updatedDate || pubDate) && (
								<>
									<div class="meta-divider" aria-hidden="true">·</div>
									<div class="meta-item">
										{updatedDate ? (
											<>Updated <FormattedDate date={updatedDate} /></>
										) : last_updated ? (
											<>Updated {last_updated}</>
										) : pubDate ? (
											<FormattedDate date={pubDate} />
										) : null}
									</div>
								</>
							)}
						</div>
					</div>
				</header>

				{heroImage && (
					<div class="hero-image">
						<div class="container">
							<Image width={1200} height={600} src={heroImage} alt="" />
						</div>
					</div>
				)}

				<div class="toc-mobile" id="toc-mobile">
					<details>
						<summary>Jump to section</summary>
						<ol id="toc-mobile-list"></ol>
					</details>
				</div>

				<div class="article-body">
					<div class="article-layout">
						<aside class="toc-desktop" id="toc-desktop" aria-label="Table of contents">
							<div class="toc-label">In this article</div>
							<ol id="toc-desktop-list"></ol>
						</aside>

						<div class="prose-container">
							<div class="prose" id="article-prose">
								<slot />
							</div>

							{authorName && (
								<div class="author-bio">
									{authorAvatar ? (
										<img src={authorAvatar} alt={authorName} class="author-bio-avatar author-bio-avatar-img" width="56" height="56" />
									) : (
										<div class="author-bio-avatar" aria-hidden="true">{authorName.charAt(0)}</div>
									)}
									<div class="author-bio-text">
										<div class="author-bio-name">{authorName}</div>
										{authorRole && <div class="author-bio-role">{authorRole}</div>}
										<p>{authorBio || "Writes about running small service businesses without the ops chaos. Builds Arca — the AI ops platform for coaches and consultants."}</p>
									</div>
								</div>
							)}

							<div class="inline-newsletter">
								<h4>Get the next playbook</h4>
								<p>One operations deep-dive a week. No spam, just the stuff we'd tell a friend over coffee.</p>
								<form action="/#waitlist" method="get">
									<input type="email" name="email" placeholder="you@example.com" required />
									<button type="submit">Subscribe</button>
								</form>
							</div>

							{(prev || next) && (
								<nav class="prev-next" aria-label="Previous and next post">
									{prev ? (
										<a href={`/blog/${prev.id}`} class="pn-link pn-prev">
											<span class="pn-label">← Previous</span>
											<span class="pn-title">{prev.title}</span>
										</a>
									) : (
										<span class="pn-spacer"></span>
									)}
									{next ? (
										<a href={`/blog/${next.id}`} class="pn-link pn-next">
											<span class="pn-label">Next →</span>
											<span class="pn-title">{next.title}</span>
										</a>
									) : (
										<span class="pn-spacer"></span>
									)}
								</nav>
							)}

							<footer class="article-footer">
								<div class="share-row">
									<span class="share-label">Share this article</span>
									<div class="share-links">
										<a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonicalUrl)}`} target="_blank" rel="noopener" aria-label="Share on Twitter">
											<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
										</a>
										<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
											<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
										</a>
										<button type="button" id="copy-link-btn" aria-label="Copy link">
											<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
										</button>
									</div>
								</div>
							</footer>
						</div>
					</div>
				</div>

				{related.length > 0 && (
					<section class="related-posts">
						<div class="related-posts-inner">
							<h3>Keep reading</h3>
							<div class="related-grid">
								{related.map((post) => {
									const pData = post.data as any;
									const pCat = resolveCluster(pData.cluster).label;
									return (
										<a href={`/blog/${post.id}`} class="related-card">
											{pCat && pCat !== 'Learn' && <div class="related-eyebrow">{pCat}</div>}
											<h4>{pData.title}</h4>
										</a>
									);
								})}
							</div>
						</div>
					</section>
				)}
			</article>
		</main>
		<Footer />

		<button type="button" id="back-to-top" class="back-to-top" aria-label="Back to top" hidden>
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="18 15 12 9 6 15"/>
			</svg>
		</button>

		<script>
			// ===== Quick-answer callout + drop cap =====
			const prose = document.querySelector('.prose');
			if (prose) {
				let quickAnswerFound = false;
				const paragraphs = prose.querySelectorAll(':scope > p');
				paragraphs.forEach((p) => {
					const html = p.innerHTML.trim();
					if (html.startsWith('<strong>Quick answer:</strong>') || html.toLowerCase().startsWith('quick answer:')) {
						p.classList.add('quick-answer');
						quickAnswerFound = true;
					}
				});
				const capTarget = Array.from(paragraphs).find((p, i) => {
					if (quickAnswerFound) {
						const prev = (p as HTMLElement).previousElementSibling;
						return prev && (prev as HTMLElement).classList.contains('quick-answer');
					}
					return i === 0;
				});
				if (capTarget) capTarget.classList.add('drop-cap');
			}

			// ===== Build TOC from H2/H3 (IDs already SSR'd by rehype-slug) =====
			function slugify(t: string) {
				return t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 60);
			}
			const headings = prose ? prose.querySelectorAll('h2, h3') : [];
			const tocDesktopList = document.getElementById('toc-desktop-list');
			const tocMobileList = document.getElementById('toc-mobile-list');
			const tocItems: { id: string; el: Element }[] = [];

			headings.forEach((h) => {
				if (!h.id) h.id = slugify((h.textContent || '').replace(/#$/, '').trim());
				const level = h.tagName === 'H3' ? 3 : 2;
				// Strip trailing "#" from rehype-autolink-headings when building TOC label
				const label = (h.textContent || '').replace(/#$/, '').trim();
				const li = `<li class="level-${level}"><a href="#${h.id}">${label}</a></li>`;
				if (tocDesktopList) tocDesktopList.insertAdjacentHTML('beforeend', li);
				if (tocMobileList) tocMobileList.insertAdjacentHTML('beforeend', li);
				tocItems.push({ id: h.id, el: h });
			});

			if (tocItems.length === 0) {
				document.getElementById('toc-desktop')?.style.setProperty('display', 'none');
				document.getElementById('toc-mobile')?.style.setProperty('display', 'none');
			}

			const tocLinks = document.querySelectorAll('.toc-desktop a');
			if ('IntersectionObserver' in window && tocItems.length > 0) {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								const id = (entry.target as HTMLElement).id;
								tocLinks.forEach((a) => {
									a.classList.toggle('active', a.getAttribute('href') === `#${id}`);
								});
							}
						});
					},
					{ rootMargin: '-100px 0px -66% 0px', threshold: 0 }
				);
				tocItems.forEach((item) => observer.observe(item.el));
			}

			// ===== Reading progress bar + back-to-top visibility =====
			const progress = document.getElementById('reading-progress');
			const article = document.querySelector('.article-body');
			const backToTop = document.getElementById('back-to-top');
			function updateProgress() {
				if (!article || !progress) return;
				const rect = (article as HTMLElement).getBoundingClientRect();
				const total = (article as HTMLElement).offsetHeight - window.innerHeight;
				const scrolled = Math.max(0, -rect.top);
				const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
				progress.style.width = pct + '%';

				if (backToTop) {
					const shouldShow = window.scrollY > window.innerHeight;
					if (shouldShow) backToTop.removeAttribute('hidden');
					else backToTop.setAttribute('hidden', '');
				}
			}
			window.addEventListener('scroll', updateProgress, { passive: true });
			updateProgress();

			if (backToTop) {
				backToTop.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			}

			// ===== Copy link button =====
			const copyBtn = document.getElementById('copy-link-btn');
			if (copyBtn) {
				copyBtn.addEventListener('click', async () => {
					try {
						await navigator.clipboard.writeText(window.location.href);
						const original = copyBtn.innerHTML;
						copyBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
						setTimeout(() => { copyBtn.innerHTML = original; }, 1600);
					} catch {}
				});
			}
		</script>
	</body>
</html>

<style>
	main.article {
		background: var(--canvas);
	}

	.skip-to-content {
		position: absolute;
		left: -9999px;
		top: 0;
		background: var(--charcoal);
		color: var(--canvas);
		padding: 0.75rem 1.25rem;
		font-weight: 600;
		z-index: 1000;
		border-radius: 0 0 var(--radius) 0;
	}
	.skip-to-content:focus {
		left: 0;
		outline: 2px solid var(--amber);
		outline-offset: 2px;
	}

	.breadcrumb {
		padding: 1.25rem 0 0;
	}
	.breadcrumb-inner {
		max-width: 1120px;
		margin: 0 auto;
		padding: 0 1.25rem;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
		font-size: 0.8125rem;
		color: var(--haze);
	}
	.breadcrumb-inner a {
		color: var(--haze);
		text-decoration: none;
		transition: color 0.2s var(--ease);
	}
	.breadcrumb-inner a:hover { color: var(--charcoal); }
	.breadcrumb-inner .sep { opacity: 0.4; }

	.article-header {
		padding: 2rem 0 2.5rem;
		text-align: center;
	}

	.eyebrow {
		display: inline-block;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--amber);
		margin-bottom: 1.25rem;
		text-decoration: none;
	}

	.eyebrow:hover { color: var(--amber-hover); }

	.article-title {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 800;
		line-height: 1.1;
		color: var(--charcoal);
		margin: 0 0 1.25rem 0;
		letter-spacing: -0.025em;
	}

	.article-deck {
		font-size: clamp(1.125rem, 2vw, 1.3125rem);
		line-height: 1.55;
		color: var(--soft-charcoal);
		max-width: 600px;
		margin: 0 auto 2.25rem;
	}

	.article-meta {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.75rem;
		font-size: 0.9375rem;
		color: var(--haze);
	}

	.byline { display: flex; align-items: center; gap: 0.625rem; }

	.avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: var(--amber);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-weight: 700;
		font-size: 0.9375rem;
	}
	.avatar-img {
		padding: 0;
		object-fit: cover;
	}

	.byline-text { text-align: left; line-height: 1.2; }
	.byline-name { font-weight: 600; color: var(--charcoal); font-size: 0.9375rem; }
	.byline-role { font-size: 0.75rem; color: var(--haze); }
	.meta-divider { color: var(--haze); opacity: 0.5; }
	.meta-item { font-size: 0.875rem; }

	.author-bio-avatar-img {
		object-fit: cover;
	}

	.hero-image { margin: 2rem 0 3rem; }

	.hero-image img {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-lg);
	}

	.article-body { padding: 1rem 0 4rem; }
	.article-footer { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--cloud); }

	.share-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.share-label {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--haze);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.share-links { display: flex; gap: 0.5rem; }

	.share-links a,
	.share-links button {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: var(--cloud);
		color: var(--charcoal);
		transition: all 0.2s var(--ease);
	}

	.share-links a:hover,
	.share-links button:hover {
		background: var(--amber);
		color: #fff;
	}

	/* Prev/next nav */
