---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { rawContent?: string };

const {
	title,
	description,
	meta_description,
	pubDate,
	updatedDate,
	last_updated,
	heroImage,
	author,
	cluster,
	target_keyword,
	word_count,
} = Astro.props;

const pageDescription = meta_description || description || '';
const authorName = typeof author === 'string' ? author : author?.name;
const authorRole = typeof author === 'object' ? author?.role : undefined;

// Estimate reading time from word_count (fallback to 5 min)
const parseWordCount = (wc: string | number | undefined): number => {
	if (!wc) return 0;
	const str = String(wc).replace(/[^0-9]/g, '');
	return parseInt(str, 10) || 0;
};
const wordCountNum = parseWordCount(word_count);
const readingMinutes = wordCountNum > 0 ? Math.max(1, Math.round(wordCountNum / 220)) : 5;

// Extract category label from cluster string (e.g. "C1 — Managed Operations" → "Managed Operations")
const categoryLabel = cluster ? cluster.replace(/^C\d+\s*[—-]\s*/, '').trim() : 'Learn';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={pageDescription} />
	</head>

	<body>
		<Header />
		<main class="article">
			<article>
				<header class="article-header">
					<div class="prose-container">
						<a href="/blog/" class="eyebrow">{categoryLabel}</a>
						<h1 class="article-title">{title}</h1>
						{pageDescription && <p class="article-deck">{pageDescription}</p>}

						<div class="article-meta">
							{authorName && (
								<div class="byline">
									<div class="avatar" aria-hidden="true">{authorName.charAt(0)}</div>
									<div class="byline-text">
										<div class="byline-name">{authorName}</div>
										{authorRole && <div class="byline-role">{authorRole}</div>}
									</div>
								</div>
							)}
							<div class="meta-divider" aria-hidden="true">·</div>
							<div class="meta-item">
								{readingMinutes} min read
							</div>
							{(last_updated || updatedDate || pubDate) && (
								<>
									<div class="meta-divider" aria-hidden="true">·</div>
									<div class="meta-item">
										{updatedDate ? (
											<>Updated <FormattedDate date={updatedDate} /></>
										) : last_updated ? (
											<>Updated {last_updated}</>
										) : pubDate ? (
											<FormattedDate date={pubDate} />
										) : null}
									</div>
								</>
							)}
						</div>
					</div>
				</header>

				{heroImage && (
					<div class="hero-image">
						<div class="container">
							<Image width={1200} height={600} src={heroImage} alt="" />
						</div>
					</div>
				)}

				<div class="article-body">
					<div class="prose-container">
						<div class="prose">
							<slot />
						</div>

						<footer class="article-footer">
							<div class="share-row">
								<span class="share-label">Share this article</span>
								<div class="share-links">
									<a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://runarca.xyz${Astro.url.pathname}`)}`} target="_blank" rel="noopener" aria-label="Share on Twitter">
										<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
									</a>
									<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://runarca.xyz${Astro.url.pathname}`)}`} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
										<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
									</a>
								</div>
							</div>

							<div class="cta-card">
								<h3>Run your operations on Arca</h3>
								<p>Built for coaches and consultants who'd rather coach than chase invoices. Set up for you in 7 days.</p>
								<a href="/#waitlist" class="btn btn-primary">Get started</a>
							</div>
						</footer>
					</div>
				</div>
			</article>
		</main>
		<Footer />

		<script>
			// Auto-wrap "Quick answer:" paragraphs in callout class
			document.querySelectorAll('.prose p').forEach((p) => {
				const html = p.innerHTML.trim();
				if (html.startsWith('<strong>Quick answer:</strong>') || html.toLowerCase().startsWith('quick answer:')) {
					p.classList.add('quick-answer');
				}
			});
		</script>
	</body>
</html>

<style>
	main.article {
		background: var(--canvas);
	}

	.article-header {
		padding: 4rem 0 2.5rem;
		text-align: center;
	}

	.eyebrow {
		display: inline-block;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--amber);
		margin-bottom: 1.25rem;
		text-decoration: none;
	}

	.eyebrow:hover {
		color: var(--amber-hover);
	}

	.article-title {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 800;
		line-height: 1.1;
		color: var(--charcoal);
		margin: 0 0 1.25rem 0;
		letter-spacing: -0.025em;
	}

	.article-deck {
		font-size: clamp(1.125rem, 2vw, 1.3125rem);
		line-height: 1.55;
		color: var(--soft-charcoal);
		max-width: 600px;
		margin: 0 auto 2.25rem;
	}

	.article-meta {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.75rem;
		font-size: 0.9375rem;
		color: var(--haze);
	}

	.byline {
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: var(--amber);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-weight: 700;
		font-size: 0.9375rem;
	}

	.byline-text {
		text-align: left;
		line-height: 1.2;
	}

	.byline-name {
		font-weight: 600;
		color: var(--charcoal);
		font-size: 0.9375rem;
	}

	.byline-role {
		font-size: 0.75rem;
		color: var(--haze);
	}

	.meta-divider {
		color: var(--haze);
		opacity: 0.5;
	}

	.meta-item {
		font-size: 0.875rem;
	}

	.hero-image {
		margin: 2rem 0 3rem;
	}

	.hero-image img {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-lg);
	}

	.article-body {
		padding-bottom: 4rem;
	}

	.article-footer {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--cloud);
	}

	.share-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.share-label {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--haze);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.share-links {
		display: flex;
		gap: 0.5rem;
	}

	.share-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: var(--cloud);
		color: var(--charcoal);
		transition: all 0.2s var(--ease);
	}

	.share-links a:hover {
		background: var(--amber);
		color: #fff;
	}

	.cta-card {
		background: var(--charcoal);
		color: var(--canvas);
		padding: 2.5rem 2rem;
		border-radius: var(--radius-lg);
		text-align: center;
	}

	.cta-card h3 {
		font-size: 1.5rem;
		color: var(--canvas);
		margin-bottom: 0.5rem;
	}

	.cta-card p {
		color: rgba(253, 250, 245, 0.8);
		font-size: 1rem;
		max-width: 440px;
		margin: 0 auto 1.5rem;
	}

	@media (max-width: 768px) {
		.article-header {
			padding: 2.5rem 0 1.5rem;
		}

		.article-meta {
			gap: 0.5rem;
		}

		.byline {
			width: 100%;
			justify-content: center;
			margin-bottom: 0.5rem;
		}

		.share-row {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
		}

		.cta-card {
			padding: 2rem 1.5rem;
		}
	}
</style>
